# Copy to .env and fill in with values from `matchday-api`'s CDK deploy output
# (npm run deploy in that repo prints ApiUrl, UserPoolId, UserPoolClientId).
# Public by design (EXPO_PUBLIC_*): these are client-embedded, not secrets.

EXPO_PUBLIC_API_URL=https://your-function-url.lambda-url.eu-west-2.on.aws/
EXPO_PUBLIC_COGNITO_USER_POOL_ID=eu-west-2_xxxxxxxxx
EXPO_PUBLIC_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
